	measure 'Strike Rate %' = ```
			var _callswithOrders = CALCULATE(DISTINCTCOUNT(fac_storevisit[Store Visit]),fac_storevisit[Completed Orders]>0)*100    
			var _storeVisits = CALCULATE(DISTINCTCOUNT(fac_storevisit[Store Visit]),fac_storevisit[Status]="Completed")
			return  
			DIVIDE(_callswithOrders, _storeVisits)
			
