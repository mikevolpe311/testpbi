table dim_cg_time
	lineageTag: 189821cf-6051-4f1e-926a-8e46fb958225

	calculationGroup
		precedence: 1

		calculationItem Current = CALCULATE(SELECTEDMEASURE(), DATESQTD('dim_date'[Dim_Date]))

		calculationItem YTD = CALCULATE(SELECTEDMEASURE(), DATESYTD('dim_date'[Dim_Date],"30/6"))

		calculationItem MAT = ```
				CALCULATE(SELECTEDMEASURE(), 
				DATESINPERIOD('dim_date'[Dim_Date],LASTDATE('dim_date'[Dim_Date]),-1,YEAR) 
				)
				
				
				```

	column Time
		dataType: string
