	measure 'MSL %' = ```
			
			var _mslRanged = CALCULATE(DISTINCTCOUNT(fac_audit[Audit]),fac_audit[Ranged] = true,fac_audit[Out Of Stock] = false, fac_audit[In Standard Range] = true)	
			var _totalRanged = CALCULATE(DISTINCTCOUNT(fac_audit[Audit]), fac_audit[In Standard Range] = true)	
			return	
			    DIVIDE(_mslRanged, _totalRanged)	 
